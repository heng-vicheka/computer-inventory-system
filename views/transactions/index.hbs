<div class="row g-4">

	{{!-- Check Out --}}
	<div class="col-md-6">
		<div class="card border-0 shadow-sm h-100">
			<div class="card-body p-4 d-flex flex-column">
				<h6 class="fw-semibold mb-4">Check out an item</h6>

				<div id="checkout-alert"></div>

				<form id="checkout-form" class="d-flex flex-column flex-grow-1">
					<div class="mb-3">
						<label class="form-label text-muted small mb-1">Item (serial #)</label>
						{{#if availableDevices}}
						<select name="deviceId" class="form-select form-select-sm" required>
							<option value="">Select item…</option>
							{{#each availableDevices}}
							<option value="{{this.id}}">
								{{this.serial_number}} — {{this.model_name}} (Available)
							</option>
							{{/each}}
						</select>
						{{else}}
						<div class="form-control form-control-sm text-muted bg-light">No available devices</div>
						{{/if}}
					</div>

					<div class="mb-3">
						<label class="form-label text-muted small mb-1">Assign to user</label>
						<select name="userId" class="form-select form-select-sm" required>
							<option value="">Select user…</option>
							{{#each users}}
							<option value="{{this.id}}">{{this.name}}</option>
							{{/each}}
						</select>
					</div>

					<div class="mb-4">
						<label class="form-label text-muted small mb-1">Reference document</label>
						<input type="file" class="form-control form-control-sm" />
					</div>

					<div class="mt-auto text-end">
						<button type="submit" class="btn btn-sm px-4 text-white"
								style="background:#2d4b8e" {{#unless availableDevices}}disabled{{/unless}}>
							Check out
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	{{!-- Check In --}}
	<div class="col-md-6">
		<div class="card border-0 shadow-sm h-100">
			<div class="card-body p-4 d-flex flex-column">
				<h6 class="fw-semibold mb-4">Check in an item</h6>

				<div id="checkin-alert"></div>

				<form id="checkin-form" class="d-flex flex-column flex-grow-1">
					<div class="mb-3">
						<label class="form-label text-muted small mb-1">Item (serial #)</label>
						{{#if activeCheckouts}}
						<select name="historyId" id="checkinSelect" class="form-select form-select-sm" required>
							<option value="" data-user="">Select item…</option>
							{{#each activeCheckouts}}
							<option value="{{this.id}}" data-user="{{this.user_name}}">
								{{this.serial_number}} — {{this.model_name}} ({{this.user_name}})
							</option>
							{{/each}}
						</select>
						{{else}}
						<div class="form-control form-control-sm text-muted bg-light">No active checkouts</div>
						{{/if}}
					</div>

					<div class="mb-3">
						<label class="form-label text-muted small mb-1">Returned by</label>
						<input type="text" id="returnedBy" class="form-control form-control-sm bg-light"
							   readonly placeholder="Auto-filled from selection" />
					</div>

					<div class="mb-4">
						<label class="form-label text-muted small mb-1">Inspection document</label>
						<input type="file" class="form-control form-control-sm" />
					</div>

					<div class="mt-auto text-end">
						<button type="submit" class="btn btn-sm px-4 text-white"
								style="background:#2d4b8e" {{#unless activeCheckouts}}disabled{{/unless}}>
							Check in
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>

</div>

<script>
	const checkinSelect = document.getElementById('checkinSelect')
	const returnedBy = document.getElementById('returnedBy')
	if (checkinSelect) {
		checkinSelect.addEventListener('change', () => {
			const opt = checkinSelect.options[checkinSelect.selectedIndex]
			returnedBy.value = opt.dataset.user || ''
		})
	}

	function showAlert(containerId, type, message) {
		const el = document.getElementById(containerId)
		el.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show py-2 small" role="alert">
			${message}
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>`
	}

	document.getElementById('checkout-form').addEventListener('submit', async (e) => {
		e.preventDefault()
		const form = e.target
		const deviceId = form.querySelector('[name="deviceId"]')?.value
		const userId = form.querySelector('[name="userId"]')?.value

		try {
			const res = await fetch('/api/transactions/checkout', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ deviceId: Number(deviceId), userId: Number(userId) }),
			})
			const data = await res.json()
			if (!res.ok) {
				showAlert('checkout-alert', 'danger', data.error || 'Checkout failed.')
			} else {
				showAlert('checkout-alert', 'success', 'Device checked out successfully.')
				setTimeout(() => location.reload(), 1000)
			}
		} catch {
			showAlert('checkout-alert', 'danger', 'Network error. Please try again.')
		}
	})

	document.getElementById('checkin-form').addEventListener('submit', async (e) => {
		e.preventDefault()
		const form = e.target
		const historyId = form.querySelector('[name="historyId"]')?.value

		try {
			const res = await fetch('/api/transactions/checkin', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ historyId: Number(historyId) }),
			})
			const data = await res.json()
			if (!res.ok) {
				showAlert('checkin-alert', 'danger', data.error || 'Check-in failed.')
			} else {
				showAlert('checkin-alert', 'success', 'Device checked in successfully.')
				setTimeout(() => location.reload(), 1000)
			}
		} catch {
			showAlert('checkin-alert', 'danger', 'Network error. Please try again.')
		}
	})
</script>
