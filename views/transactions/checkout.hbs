<div class="row justify-content-center">
	<div class="col-lg-6">
		<div class="d-flex align-items-center gap-2 mb-4">
			<a href="/items" class="btn btn-sm btn-outline-secondary">
				<i class="bi bi-arrow-left"></i>
			</a>
			<div>
				<h2 class="fw-bold mb-0">Check Out Item</h2>
				<p class="text-muted mb-0">Assign an available item to a user</p>
			</div>
		</div>

		<div class="card border-0 shadow-sm">
			<div class="card-body p-4">
				<form action="/transactions/checkout" method="POST" enctype="multipart/form-data" novalidate>
					<div class="mb-3">
						<label for="itemId" class="form-label fw-semibold">Item <span class="text-danger">*</span></label>
						<select id="itemId" name="itemId" class="form-select" required>
							<option value="" disabled selected>Select available item</option>
							{{#each availableItems}}
							<option
								value="{{this._id}}"
								{{#if (eq ../selectedItemId this._id)}}selected{{/if}}
							>{{this.brand}} {{this.model}} — {{this.serialNumber}}</option>
							{{/each}}
						</select>
					</div>

					<div class="mb-3">
						<label for="assignedTo" class="form-label fw-semibold">Assign To <span class="text-danger">*</span></label>
						<select id="assignedTo" name="assignedTo" class="form-select" required>
							<option value="" disabled selected>Select user</option>
							{{#each users}}
							<option value="{{this._id}}">{{this.username}}</option>
							{{/each}}
						</select>
					</div>

					<div class="mb-4">
						<label for="document" class="form-label fw-semibold">
							Reference Document <span class="text-danger">*</span>
							<span class="text-muted fw-normal small">(PDF, image)</span>
						</label>
						<input
							type="file"
							id="document"
							name="document"
							class="form-control"
							accept=".pdf,.jpg,.jpeg,.png"
							required
						/>
					</div>

					<div class="d-flex justify-content-end gap-2">
						<a href="/items" class="btn btn-outline-secondary">Cancel</a>
						<button type="submit" class="btn btn-primary">
							<i class="bi bi-box-arrow-up me-1"></i>Confirm Check Out
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>
