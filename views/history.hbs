<div class="section">
	<div class="section-header">
		<span class="section-title">Asset history</span>
		<form class="search-bar" method="GET" action="/history">
			<input type="text" name="search" placeholder="Search by serial #..." value="{{searchQuery}}" />
			<button type="submit" class="btn btn-primary btn-sm">Search</button>
			{{#if searchQuery}}
				<a href="/history" class="btn btn-sm">Clear</a>
			{{/if}}
		</form>
	</div>

	{{#if (isEmpty groupedHistory)}}
		<div class="empty">
			{{#if searchQuery}}No history found for "{{searchQuery}}"{{else}}No history records found.{{/if}}
		</div>
	{{else}}
		{{#each groupedHistory}}
			<div class="asset-label">{{@key}}</div>
			{{#each this}}
				{{#if dateCheckedOutFormatted}}
					<div class="history-row">
						<div class="history-dot green"></div>
						<div>
							<div><strong>Checked in</strong> from {{userName}}</div>
							<div class="history-meta">{{dateCheckedOutFormatted}} · Duration: {{duration}}</div>
						</div>
					</div>
					<div class="history-row">
						<div class="history-dot"></div>
						<div>
							<div><strong>Checked out</strong> to {{userName}}</div>
							<div class="history-meta">{{dateCheckedInFormatted}}</div>
						</div>
					</div>
				{{else}}
					<div class="history-row">
						<div class="history-dot"></div>
						<div>
							<div><strong>Checked out</strong> to {{userName}}</div>
							<div class="history-meta">{{dateCheckedInFormatted}} · Duration: ongoing</div>
						</div>
					</div>
				{{/if}}
			{{/each}}
		{{/each}}
	{{/if}}
</div>
