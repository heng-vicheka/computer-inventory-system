<div class="d-flex align-items-center gap-2 mb-4">
	<a href="/items/{{item._id}}" class="btn btn-sm btn-outline-secondary">
		<i class="bi bi-arrow-left"></i>
	</a>
	<div>
		<h2 class="fw-bold mb-0">Asset History</h2>
		<p class="text-muted mb-0">{{item.brand}} {{item.model}} &mdash; <span class="font-monospace">{{item.serialNumber}}</span></p>
	</div>
</div>

<div class="card border-0 shadow-sm">
	<div class="table-responsive">
		<table class="table table-hover align-middle mb-0">
			<thead class="table-dark">
				<tr>
					<th>Event</th>
					<th>Assigned To</th>
					<th>Checked Out</th>
					<th>Checked In</th>
					<th>Duration</th>
					<th>Reference Doc</th>
				</tr>
			</thead>
			<tbody>
				{{#each transactions}}
				<tr>
					<td>
						{{#if this.checkedInAt}}
						<span class="badge bg-success">Check-In</span>
						{{else}}
						<span class="badge bg-primary">Check-Out</span>
						{{/if}}
					</td>
					<td>{{this.assignedTo.username}}</td>
					<td class="small">{{formatDate this.checkedOutAt}}</td>
					<td class="small">{{#if this.checkedInAt}}{{formatDate this.checkedInAt}}{{else}}<span class="text-muted">—</span>{{/if}}</td>
					<td class="small">{{this.duration}}</td>
					<td>
						{{#if this.document}}
						<a href="/uploads/{{this.document}}" target="_blank" class="btn btn-sm btn-outline-secondary">
							<i class="bi bi-file-earmark me-1"></i>View
						</a>
						{{else}}
						<span class="text-muted">—</span>
						{{/if}}
					</td>
				</tr>
				{{else}}
				<tr>
					<td colspan="6" class="text-center text-muted py-5">
						<i class="bi bi-clock-history fs-2 d-block mb-2"></i>No history recorded
					</td>
				</tr>
				{{/each}}
			</tbody>
		</table>
	</div>
</div>
