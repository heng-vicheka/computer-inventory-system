<div class="mb-4">
	<h2 class="fw-bold mb-0">Reports</h2>
	<p class="text-muted">Inventory analytics and audit data</p>
</div>

<div class="row g-4">
	<!-- Inventory Status -->
	<div class="col-lg-6">
		<div class="card border-0 shadow-sm h-100">
			<div class="card-header bg-transparent fw-semibold">
				<i class="bi bi-pie-chart me-2"></i>Inventory Status Summary
			</div>
			<div class="card-body">
				<table class="table table-sm mb-0">
					<tbody>
						<tr>
							<td>Total Items</td>
							<td class="text-end fw-bold">{{statusReport.total}}</td>
						</tr>
						<tr>
							<td><span class="badge bg-success me-1">Available</span></td>
							<td class="text-end">{{statusReport.available}}</td>
						</tr>
						<tr>
							<td><span class="badge bg-primary me-1">In-Use</span></td>
							<td class="text-end">{{statusReport.inUse}}</td>
						</tr>
						<tr>
							<td><span class="badge bg-warning me-1">Maintenance</span></td>
							<td class="text-end">{{statusReport.maintenance}}</td>
						</tr>
						<tr>
							<td><span class="badge bg-secondary me-1">Retired</span></td>
							<td class="text-end">{{statusReport.retired}}</td>
						</tr>
					</tbody>
				</table>
			</div>
		</div>
	</div>

	<!-- Asset Aging -->
	<div class="col-lg-6">
		<div class="card border-0 shadow-sm h-100">
			<div class="card-header bg-transparent fw-semibold d-flex justify-content-between align-items-center">
				<span><i class="bi bi-calendar-x me-2"></i>Aging Assets (&gt; 3 years)</span>
				<span class="badge bg-warning text-dark">{{agingItems.length}} items</span>
			</div>
			<div class="card-body p-0">
				<div class="table-responsive" style="max-height: 260px; overflow-y: auto">
					<table class="table table-sm table-hover align-middle mb-0">
						<thead class="table-light sticky-top">
							<tr>
								<th>Item</th>
								<th>Category</th>
								<th>Acquired</th>
							</tr>
						</thead>
						<tbody>
							{{#each agingItems}}
							<tr>
								<td>
									<a href="/items/{{this._id}}" class="text-decoration-none fw-semibold">
										{{this.brand}} {{this.model}}
									</a>
								</td>
								<td class="small">{{this.category}}</td>
								<td class="small text-muted">{{formatDate this.dateAcquired}}</td>
							</tr>
							{{else}}
							<tr>
								<td colspan="3" class="text-center text-muted py-3">No aging assets</td>
							</tr>
							{{/each}}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>

	<!-- User Audit -->
	<div class="col-12">
		<div class="card border-0 shadow-sm">
			<div class="card-header bg-transparent fw-semibold">
				<i class="bi bi-person-lines-fill me-2"></i>User Asset Audit
			</div>
			<div class="card-body">
				<form method="GET" action="/reports" class="row g-2 align-items-end mb-3">
					<div class="col-sm-6 col-md-4">
						<label class="form-label small fw-semibold">Select User</label>
						<select name="userId" class="form-select">
							<option value="">-- Select a user --</option>
							{{#each users}}
							<option value="{{this._id}}" {{#if (eq ../selectedUserId this._id)}}selected{{/if}}>{{this.username}}</option>
							{{/each}}
						</select>
					</div>
					<div class="col-auto">
						<button type="submit" class="btn btn-dark">
							<i class="bi bi-search me-1"></i>View Assets
						</button>
					</div>
				</form>

				{{#if userAssets}}
				<div class="table-responsive">
					<table class="table table-hover align-middle mb-0">
						<thead class="table-dark">
							<tr>
								<th>Item</th>
								<th>Serial No.</th>
								<th>Category</th>
								<th>Status</th>
								<th>Checked Out</th>
							</tr>
						</thead>
						<tbody>
							{{#each userAssets}}
							<tr>
								<td class="fw-semibold">{{this.item.brand}} {{this.item.model}}</td>
								<td class="font-monospace small">{{this.item.serialNumber}}</td>
								<td>{{this.item.category}}</td>
								<td>
									<span class="badge bg-{{statusBadge this.item.status}}">{{this.item.status}}</span>
								</td>
								<td class="small text-muted">{{formatDate this.checkedOutAt}}</td>
							</tr>
							{{else}}
							<tr>
								<td colspan="5" class="text-center text-muted py-4">No assets found for this user</td>
							</tr>
							{{/each}}
						</tbody>
					</table>
				</div>
				{{/if}}
			</div>
		</div>
	</div>
</div>
