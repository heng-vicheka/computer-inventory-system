<div class="section">
	<div class="section-header">
		<span class="section-title">All items</span>
		<div class="search-bar">
			<input type="text" placeholder="Search..." />
			<select>
				<option>All categories</option>
				<option>Laptop</option>
				<option>Desktop</option>
				<option>Monitor</option>
				<option>Keyboard</option>
				<option>Server</option>
			</select>
			<select>
				<option>All statuses</option>
				<option>Available</option>
				<option>In-Use</option>
				<option>Maintenance</option>
				<option>Retired</option>
			</select>
				<button type="button" class="btn btn-primary" onclick="openModal()">+ Add item</button>
		</div>
	</div>
	<table>
		<thead>
			<tr>
				<th>Serial #</th>
				<th></th>
				<th>Model</th>
				<th>Brand</th>
				<th>Category</th>
				<th>Status</th>
				<th>Acquired</th>
				<th></th>
			</tr>
		</thead>
		<tbody>
			{{#if devices.length}}
				{{#each devices}}
					<tr>
						<td>{{serialNumber}}</td>
						<td><img class="table-thumb" src="{{pictureUrl}}" alt="{{modelName}}" /></td>
						<td>{{modelName}}</td>
						<td>{{brand}}</td>
						<td>{{category}}</td>
						<td><span class="badge {{statusClass}}">{{status}}</span></td>
						<td>{{formatDate dateAcquired}}</td>
						<td>
							<div class="action-buttons">
								<button class="btn btn-secondary btn-sm">Edit</button>
								<button class="btn btn-danger btn-sm">Delete</button>
							</div>
						</td>
					</tr>
				{{/each}}
			{{else}}
				<tr>
					<td colspan="8" class="empty">No inventory items found.</td>
				</tr>
			{{/if}}
		</tbody>
	</table>
	</div>
	<div class="modal-overlay" id="modal">
		<div class="modal">
			<div class="modal-header">
				<span style="font-size: 14px; font-weight: 500">Add new item</span>
				<span class="modal-close" onclick="closeModal()">&#x2715;</span>
			</div>
			<div class="form-grid">
				<div class="form-group">
					<label>Serial number</label><input id="new-serial" type="text" placeholder="SN-XXXX" />
				</div>
				<div class="form-group">
					<label>Model</label><input id="new-model" type="text" placeholder="e.g. XPS 15" />
				</div>
				<div class="form-group">
					<label>Brand</label><input id="new-brand" type="text" placeholder="e.g. Dell" />
				</div>
				<div class="form-group">
					<label>Category</label><select id="new-category">
						<option>Laptop</option>
						<option>Desktop</option>
						<option>Server</option>
						<option>Monitor</option>
						<option>Keyboard</option>
						<option>Other</option>
					</select>
				</div>
				<div class="form-group">
					<label>Status</label><select id="new-status">
						<option>Available</option>
						<option>In-Use</option>
						<option>Maintenance</option>
						<option>Retired</option>
					</select>
				</div>
				<div class="form-group">
					<label>Date acquired</label><input id="new-acquired" type="date" />
				</div>
				<div class="form-group full">
					<label>Device image</label>
					<div class="image-input">
						<label class="btn" for="device-image-input">Select image</label>
						<input id="device-image-input" type="file" accept="image/*" />
						<img id="device-image-preview" class="image-preview" src="" alt="Device preview" hidden />
					</div>
				</div>
			</div>
			<div class="form-actions">
				<button type="button" class="btn" onclick="closeModal()">Cancel</button>
				<button type="button" class="btn btn-primary" id="save-device-btn">Save item</button>
			</div>
		</div>
	</div>

<script>
	const defaultImageUrl = '/images/device-placeholder.svg'
	let selectedDeviceImage = ''

	function openModal() {
		resetNewDeviceForm()
		document.getElementById('modal').classList.add('open')
	}

	function closeModal() {
		document.getElementById('modal').classList.remove('open')
	}

	function resetNewDeviceForm() {
		document.getElementById('new-serial').value = ''
		document.getElementById('new-model').value = ''
		document.getElementById('new-brand').value = ''
		document.getElementById('new-category').value = 'Laptop'
		document.getElementById('new-status').value = 'Available'
		document.getElementById('new-acquired').value = ''
		document.getElementById('device-image-input').value = ''
		selectedDeviceImage = ''
		const preview = document.getElementById('device-image-preview')
		preview.hidden = true
		preview.src = ''
	}

	document.getElementById('device-image-input')?.addEventListener('change', function () {
		const preview = document.getElementById('device-image-preview')
		const file = this.files && this.files[0]

		if (!file) {
			selectedDeviceImage = ''
			preview.hidden = true
			preview.src = ''
			return
		}

		const reader = new FileReader()
		reader.onload = function (event) {
			selectedDeviceImage = event.target.result
			preview.src = selectedDeviceImage
			preview.hidden = false
		}
		reader.readAsDataURL(file)
	})

	document.getElementById('save-device-btn')?.addEventListener('click', async function () {
		const serialNumber = document.getElementById('new-serial').value.trim()
		const modelName = document.getElementById('new-model').value.trim()
		const brand = document.getElementById('new-brand').value.trim()
		const category = document.getElementById('new-category').value
		const status = document.getElementById('new-status').value
		const dateAcquired = document.getElementById('new-acquired').value

		if (!serialNumber || !modelName || !brand) {
			alert('Please fill in serial number, model, and brand before saving.')
			return
		}

		const payload = {
			serialNumber,
			modelName,
			brand,
			type: category,
			category,
			status,
			dateAcquired,
			pictureUrl: selectedDeviceImage || '',
		}

		try {
			const response = await fetch('/api/items', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify(payload),
			})

			if (!response.ok) {
				const error = await response.json().catch(() => null)
				throw new Error(error?.message || 'Unable to save device.')
			}

			closeModal()
			window.location.reload()
		} catch (error) {
			alert(error.message)
		}
	})

	document.getElementById('modal')?.addEventListener('click', function (e) {
		if (e.target === this) closeModal()
	})
</script>
