<div class="section">
	<div class="section-header">
		<span class="section-title">All items</span>
		<div class="search-bar">
			<input type="text" placeholder="Search..." />
			<select>
				<option>All categories</option>
				<option>Laptop</option>
				<option>Desktop</option>
				<option>Monitor</option>
				<option>Keyboard</option>
				<option>Server</option>
			</select>
			<select>
				<option>All statuses</option>
				<option>Available</option>
				<option>In-Use</option>
				<option>Maintenance</option>
				<option>Retired</option>
			</select>
				<button type="button" class="btn btn-primary" onclick="openModal()">+ Add item</button>
		</div>
	</div>
	<table>
		<thead>
			<tr>
				<th>Serial #</th>
				<th></th>
				<th>Model</th>
				<th>Brand</th>
				<th>Category</th>
				<th>Status</th>
				<th>Acquired</th>
				<th></th>
			</tr>
		</thead>
		<tbody>
			{{#if devices.length}}
				{{#each devices}}
					<tr>
						<td>{{serialNumber}}</td>
						<td><img class="table-thumb" src="{{pictureUrl}}" alt="{{modelName}}" /></td>
						<td>{{modelName}}</td>
						<td>{{brand}}</td>
						<td>{{category}}</td>
						<td><span class="badge {{statusClass}}">{{status}}</span></td>
						<td>{{formatDate dateAcquired}}</td>
						<td>
							<div class="action-buttons">
								<button class="btn btn-secondary btn-sm edit-device-btn" data-id="{{id}}" data-serial="{{serialNumber}}" data-model="{{modelName}}" data-brand="{{brand}}" data-category="{{category}}" data-status="{{status}}" data-date="{{dateAcquired}}" data-picture-url="{{pictureUrl}}">Edit</button>
								<button type="button" class="btn btn-danger btn-sm delete-device-btn" data-id="{{id}}">Delete</button>
							</div>
						</td>
					</tr>
				{{/each}}
			{{else}}
				<tr>
					<td colspan="8" class="empty">No inventory items found.</td>
				</tr>
			{{/if}}
		</tbody>
	</table>
	</div>
	{{> item-form}}

