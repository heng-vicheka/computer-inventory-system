<div class="panel block">
	<div class="stats-grid stats-grid-3">
		<div class="stat-card stat-total">
			<div class="stat-label">Total keys</div>
			<div class="stat-value">{{stats.total}}</div>
		</div>
		<div class="stat-card stat-available">
			<div class="stat-label">Active</div>
			<div class="stat-value">{{stats.active}}</div>
		</div>
		<div class="stat-card stat-maintenance">
			<div class="stat-label">Revoked</div>
			<div class="stat-value">{{stats.revoked}}</div>
		</div>
	</div>

	<div class="card api-key-card">
		<div class="card-header">
			<span class="card-title" style="margin-top: auto; margin-bottom: auto;">API keys</span>
			<button class="btn btn-primary" type="button" id="openApiKeyModal">+ Generate new key</button>
		</div>
		<div class="card-body">
			<div class="table-responsive">
				<table class="api-key-table">
					<thead>
						<tr>
							<th>Label</th>
							<th>Key preview</th>
							<th>Created</th>
							<th>Status</th>
							<th></th>
						</tr>
					</thead>
					<tbody>
						{{#each apiKeys}}
							<tr>
								<td>{{label}}</td>
								<td>
									<span class="api-key-preview-static">{{keyPreview}}</span>
								</td>
								<td>{{createdAt}}</td>
								<td>
									<span class="status-pill status-pill-{{statusClass}}">{{status}}</span>
								</td>
								<td class="table-actions">
									{{#if isRevoked}}
										<span class="api-key-revoked-action">Revoked</span>
									{{else}}
										<button class="btn btn-secondary btn-revoke" type="button" data-key-revoke="{{id}}">
											Revoke
										</button>
									{{/if}}
								</td>
							</tr>
						{{else}}
							<tr>
								<td colspan="5" class="empty-state">No API keys have been generated yet.</td>
							</tr>
						{{/each}}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

{{> api-key-form}}

<script>
	const apiKeyModal = document.getElementById('apiKeyModal')
	const openApiKeyModal = document.getElementById('openApiKeyModal')
	const apiKeyForm = document.querySelector('[data-api-key-form]')
	const apiKeyCreated = document.querySelector('[data-api-key-created]')
	const apiKeyCreatedPreview = document.querySelector('[data-created-key-preview]')
	const apiKeySubmit = document.querySelector('[data-api-key-submit]')
	const apiKeyDone = document.querySelector('[data-api-key-done]')
	const apiKeyCancel = document.querySelector('[data-api-key-cancel]')
	const apiKeyClose = document.querySelector('[data-api-key-close]')

	function closeApiKeyModal() {
		apiKeyModal?.classList.remove('open')
		apiKeyModal?.setAttribute('aria-hidden', 'true')
	}

	function resetApiKeyModal() {
		apiKeyForm?.reset()
		apiKeyForm?.querySelector('input[name="label"]')?.removeAttribute('readonly')
		apiKeyCreated?.setAttribute('hidden', '')
		apiKeySubmit?.removeAttribute('hidden')
		apiKeySubmit?.removeAttribute('disabled')
		apiKeyDone?.setAttribute('hidden', '')
		apiKeyCancel?.removeAttribute('hidden')
		apiKeyClose?.removeAttribute('hidden')

		if (apiKeyCreatedPreview) {
			apiKeyCreatedPreview.value = ''
			apiKeyCreatedPreview.dataset.fullValue = ''
		}
	}

	function copyText(value, button, copiedLabel, defaultLabel) {
		if (!value) return

		const showCopied = () => {
			button.innerHTML = '<i class="bi bi-check-lg"></i>'
			button.setAttribute('aria-label', copiedLabel)
			button.setAttribute('title', copiedLabel)
			window.setTimeout(() => {
				button.innerHTML = '<i class="bi bi-copy"></i>'
				button.setAttribute('aria-label', defaultLabel)
				button.setAttribute('title', defaultLabel)
			}, 1200)
		}

		if (navigator.clipboard) {
			navigator.clipboard.writeText(value).then(showCopied).catch(() => fallbackCopy(value, showCopied))
			return
		}

		fallbackCopy(value, showCopied)
	}

	function fallbackCopy(value, onCopied) {
		const textArea = document.createElement('textarea')
		textArea.value = value
		textArea.setAttribute('readonly', '')
		textArea.style.position = 'fixed'
		textArea.style.opacity = '0'
		document.body.appendChild(textArea)
		textArea.select()
		document.execCommand('copy')
		textArea.remove()
		onCopied()
	}

	openApiKeyModal?.addEventListener('click', () => {
		resetApiKeyModal()
		apiKeyModal?.classList.add('open')
		apiKeyModal?.setAttribute('aria-hidden', 'false')
		apiKeyModal?.querySelector('input[name="label"]')?.focus()
	})

	document.querySelectorAll('[data-api-key-close]').forEach((button) => {
		button.addEventListener('click', () => {
			resetApiKeyModal()
			closeApiKeyModal()
		})
	})

	apiKeyCancel?.addEventListener('click', () => {
		resetApiKeyModal()
		closeApiKeyModal()
	})

	apiKeyModal?.addEventListener('click', (event) => {
		if (event.target !== apiKeyModal || !apiKeyDone?.hasAttribute('hidden')) return
		resetApiKeyModal()
		closeApiKeyModal()
	})

	apiKeyForm?.addEventListener('submit', async (event) => {
		event.preventDefault()

		apiKeySubmit.disabled = true
		try {
			const response = await fetch(apiKeyForm.action, {
				method: 'POST',
				headers: {
					Accept: 'application/json',
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({
					label: apiKeyForm.querySelector('input[name="label"]')?.value,
				}),
			})
			const payload = await response.json()
			if (!response.ok) throw new Error(payload.error || payload.message || 'Failed to generate API key')

			const createdKey = payload.apiKey?.key
			if (!createdKey) throw new Error('Generated API key was missing from the response')

			apiKeyCreatedPreview.value = createdKey
			apiKeyCreatedPreview.dataset.fullValue = createdKey
			apiKeyForm.querySelector('input[name="label"]')?.setAttribute('readonly', '')
			apiKeyCreated?.removeAttribute('hidden')
			apiKeySubmit.setAttribute('hidden', '')
			apiKeyCancel?.setAttribute('hidden', '')
			apiKeyClose?.setAttribute('hidden', '')
			apiKeyDone?.removeAttribute('hidden')
		} catch (error) {
			apiKeySubmit.disabled = false
			window.alert(error.message || 'Failed to generate API key')
		}
	})

	document.querySelector('[data-created-key-toggle]')?.addEventListener('click', (event) => {
		const button = event.currentTarget
		if (!apiKeyCreatedPreview) return

		const isHidden = apiKeyCreatedPreview.value === apiKeyCreatedPreview.dataset.hiddenValue
		apiKeyCreatedPreview.value = isHidden
			? apiKeyCreatedPreview.dataset.fullValue
			: apiKeyCreatedPreview.dataset.hiddenValue
		button.setAttribute('aria-label', isHidden ? 'Hide generated API key' : 'Show generated API key')
		button.setAttribute('title', isHidden ? 'Hide generated API key' : 'Show generated API key')
		button.innerHTML = isHidden ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>'
	})

	document.querySelector('[data-created-key-copy]')?.addEventListener('click', (event) => {
		copyText(
			apiKeyCreatedPreview?.dataset.fullValue,
			event.currentTarget,
			'Copied generated API key',
			'Copy generated API key',
		)
	})

	apiKeyDone?.addEventListener('click', () => {
		closeApiKeyModal()
		window.location.reload()
	})

	document.querySelectorAll('[data-key-revoke]').forEach((button) => {
		button.addEventListener('click', async () => {
			const keyId = button.dataset.keyRevoke
			if (!keyId) return

			button.disabled = true
			try {
				const response = await fetch(`/api/keys/${keyId}`, { method: 'DELETE' })
				if (!response.ok) throw new Error('Failed to revoke API key')
				window.location.reload()
			} catch (_error) {
				button.disabled = false
				window.alert('Failed to revoke API key')
			}
		})
	})
</script>
