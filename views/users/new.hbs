<div class="d-flex justify-content-between align-items-center mb-4">
	<div>
		<h5 class="fw-semibold mb-0">Create User</h5>
		<small class="text-muted">Add a new user account</small>
	</div>
	<a href="/users" class="btn btn-outline-secondary btn-sm">
		<i class="bi bi-arrow-left me-1"></i>Back to Users
	</a>
</div>

{{> flash}}

{{#if errors}}
<div class="alert alert-danger">
	<strong>Please fix the following:</strong>
	<ul class="mb-0 mt-1">
		{{#each errors}}<li>{{this}}</li>{{/each}}
	</ul>
</div>
{{/if}}

<div class="card border-0 shadow-sm" style="max-width:560px">
	<div class="card-body p-4">
		<form method="POST" action="/users">
			<div class="mb-3">
				<label class="form-label fw-medium">Full Name</label>
				<input type="text" name="name" class="form-control" value="{{values.name}}" placeholder="e.g. Jane Smith" required />
			</div>

			<div class="mb-3">
				<label class="form-label fw-medium">Email Address</label>
				<input type="email" name="email" class="form-control" value="{{values.email}}" placeholder="jane@example.com" required />
			</div>

			<div class="mb-3">
				<label class="form-label fw-medium">Role</label>
				<select name="userRoleId" class="form-select" required>
					<option value="">Select role…</option>
					{{#each roles}}
					<option value="{{this.id}}" {{#if (eq this.id ../values.userRoleId)}}selected{{/if}}>{{this.name}}</option>
					{{/each}}
				</select>
			</div>

			<div class="mb-4">
				<label class="form-label fw-medium">Status</label>
				<select name="status" class="form-select" required>
					<option value="">Select status…</option>
					<option value="active"   {{#if (eq values.status 'active')}}selected{{/if}}>Active</option>
					<option value="inactive" {{#if (eq values.status 'inactive')}}selected{{/if}}>Inactive</option>
				</select>
			</div>

			<div class="d-flex gap-2">
				<button type="submit" class="btn btn-primary">
					<i class="bi bi-person-plus me-1"></i>Create User
				</button>
				<a href="/users" class="btn btn-outline-secondary">Cancel</a>
			</div>
		</form>
	</div>
</div>
