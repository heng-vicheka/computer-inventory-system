<div class="d-flex justify-content-between align-items-center mb-4">
	<div>
		<h5 class="fw-semibold mb-0">Edit User</h5>
		<small class="text-muted">{{user.name}}</small>
	</div>
	<a href="/users" class="btn btn-outline-secondary btn-sm">
		<i class="bi bi-arrow-left me-1"></i>Back to Users
	</a>
</div>

<div id="form-alert"></div>

<div class="card border-0 shadow-sm" style="max-width:560px">
	<div class="card-body p-4">
		<form id="edit-user-form">
			<div class="mb-3">
				<label class="form-label fw-medium">Full Name</label>
				<input type="text" name="name" class="form-control" value="{{user.name}}" required />
			</div>

			<div class="mb-3">
				<label class="form-label fw-medium">Email Address</label>
				<input type="email" name="email" class="form-control" value="{{user.email}}" required />
			</div>

			<div class="mb-3">
				<label class="form-label fw-medium">Role</label>
				<select name="userRoleId" class="form-select" required>
					<option value="">Select role…</option>
					{{#each roles}}
					<option value="{{this.id}}" {{#if (eq this.id ../user.user_role_id)}}selected{{/if}}>{{this.name}}</option>
					{{/each}}
				</select>
			</div>

			<div class="mb-4">
				<label class="form-label fw-medium">Status</label>
				<select name="status" class="form-select" required>
					<option value="active"   {{#if (eq user.status 'active')}}selected{{/if}}>Active</option>
					<option value="inactive" {{#if (eq user.status 'inactive')}}selected{{/if}}>Inactive</option>
				</select>
			</div>

			<div class="d-flex gap-2">
				<button type="submit" class="btn btn-primary">
					<i class="bi bi-check2 me-1"></i>Save Changes
				</button>
				<a href="/users" class="btn btn-outline-secondary">Cancel</a>
			</div>
		</form>
	</div>
</div>

<div class="mt-4" style="max-width:560px">
	<div class="card border-danger border-opacity-25">
		<div class="card-body">
			<h6 class="text-danger mb-1">Danger Zone</h6>
			<p class="text-muted small mb-3">Deleting a user is a soft delete — their data is preserved but the account is deactivated.</p>
			<button id="delete-btn" class="btn btn-outline-danger btn-sm">
				<i class="bi bi-trash me-1"></i>Delete User
			</button>
		</div>
	</div>
</div>

<script>
	const userId = {{user.id}}

	document.getElementById('edit-user-form').addEventListener('submit', async (e) => {
		e.preventDefault()
		const form = e.target
		const submitBtn = form.querySelector('[type="submit"]')
		submitBtn.disabled = true

		try {
			const res = await fetch(`/api/users/${userId}`, {
				method: 'PUT',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					name: form.name.value,
					email: form.email.value,
					userRoleId: form.userRoleId.value,
					status: form.status.value,
				}),
			})
			const data = await res.json()
			if (!res.ok) {
				document.getElementById('form-alert').innerHTML =
					`<div class="alert alert-danger">${data.error || 'Failed to update user.'}</div>`
				submitBtn.disabled = false
			} else {
				location.href = '/users?updated=1'
			}
		} catch {
			document.getElementById('form-alert').innerHTML =
				`<div class="alert alert-danger">Network error. Please try again.</div>`
			submitBtn.disabled = false
		}
	})

	document.getElementById('delete-btn').addEventListener('click', async () => {
		if (!confirm('Delete {{user.name}}? This will deactivate their account.')) return
		try {
			const res = await fetch(`/api/users/${userId}`, { method: 'DELETE' })
			if (res.ok) {
				location.href = '/users?deleted=1'
			} else {
				const data = await res.json()
				document.getElementById('form-alert').innerHTML =
					`<div class="alert alert-danger">${data.error || 'Failed to delete user.'}</div>`
			}
		} catch {
			document.getElementById('form-alert').innerHTML =
				`<div class="alert alert-danger">Network error. Please try again.</div>`
		}
	})
</script>
