<div class="d-flex justify-content-between align-items-center mb-4">
	<div>
		<h2 class="fw-bold mb-0">Users</h2>
		<p class="text-muted mb-0">{{totalUsers}} accounts</p>
	</div>
	<a href="/users/new" class="btn btn-primary">
		<i class="bi bi-person-plus me-1"></i>Add User
	</a>
</div>

<div class="card border-0 shadow-sm">
	<div class="table-responsive">
		<table class="table table-hover align-middle mb-0">
			<thead class="table-dark">
				<tr>
					<th>Username</th>
					<th>Role</th>
					<th>Status</th>
					<th>Created</th>
					<th class="text-end">Actions</th>
				</tr>
			</thead>
			<tbody>
				{{#each users}}
				<tr>
					<td class="fw-semibold">{{this.username}}</td>
					<td>
						<span class="badge bg-{{roleBadge this.role}}">{{this.role}}</span>
					</td>
					<td>
						{{#if this.isActive}}
						<span class="badge bg-success">Active</span>
						{{else}}
						<span class="badge bg-secondary">Disabled</span>
						{{/if}}
					</td>
					<td class="small text-muted">{{formatDate this.createdAt}}</td>
					<td class="text-end">
						<div class="btn-group btn-group-sm">
							<!-- Toggle Status -->
							<form action="/users/{{this._id}}/status?_method=PATCH" method="POST">
								<input type="hidden" name="isActive" value="{{#if this.isActive}}false{{else}}true{{/if}}" />
								<button
									type="submit"
									class="btn btn-sm {{#if this.isActive}}btn-outline-warning{{else}}btn-outline-success{{/if}}"
									title="{{#if this.isActive}}Disable{{else}}Enable{{/if}}"
								>
									<i class="bi bi-{{#if this.isActive}}slash-circle{{else}}check-circle{{/if}}"></i>
								</button>
							</form>
							<!-- Change Role -->
							<form action="/users/{{this._id}}/role?_method=PATCH" method="POST" class="d-inline">
								<select name="role" class="form-select form-select-sm d-inline-block w-auto" onchange="this.form.submit()">
									<option value="Technician" {{#if (eq this.role 'Technician')}}selected{{/if}}>Technician</option>
									<option value="Admin" {{#if (eq this.role 'Admin')}}selected{{/if}}>Admin</option>
								</select>
							</form>
						</div>
					</td>
				</tr>
				{{else}}
				<tr>
					<td colspan="5" class="text-center text-muted py-5">
						<i class="bi bi-people fs-2 d-block mb-2"></i>No users found
					</td>
				</tr>
				{{/each}}
			</tbody>
		</table>
	</div>
</div>
