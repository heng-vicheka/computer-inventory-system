{{!-- Stat cards (mirrors dashboard.hbs pattern) --}}
<div class="row g-3 mb-4">
	<div class="col-sm-6 col-xl-3">
		<div class="card border-0 shadow-sm h-100">
			<div class="card-body">
				<div class="text-muted small mb-1">Total users</div>
				<div class="fs-3 fw-bold text-primary">{{stats.total}}</div>
			</div>
		</div>
	</div>
	<div class="col-sm-6 col-xl-3">
		<div class="card border-0 shadow-sm h-100">
			<div class="card-body">
				<div class="text-muted small mb-1">Active</div>
				<div class="fs-3 fw-bold text-success">{{stats.active}}</div>
			</div>
		</div>
	</div>
	<div class="col-sm-6 col-xl-3">
		<div class="card border-0 shadow-sm h-100">
			<div class="card-body">
				<div class="text-muted small mb-1">Inactive</div>
				<div class="fs-3 fw-bold text-warning">{{stats.inactive}}</div>
			</div>
		</div>
	</div>
</div>

{{!-- User accounts table --}}
<div class="card border-0 shadow-sm">
	<div class="card-body px-4 pt-4 pb-0 d-flex justify-content-between align-items-center">
		<span class="fw-semibold">User accounts</span>
		<a href="/users/new" class="btn btn-sm text-white px-3" style="background:#2d4b8e">
			<i class="bi bi-person-plus me-1"></i>Create user
		</a>
	</div>

	<div class="table-responsive">
		<table class="table align-middle mb-0" style="border-collapse:separate">
			<thead>
				<tr style="border-top:1px solid #f0f0f0">
					<th class="px-4 py-3 text-muted fw-normal small">Name</th>
					<th class="py-3 text-muted fw-normal small">Email</th>
					<th class="py-3 text-muted fw-normal small">Role</th>
					<th class="py-3 text-muted fw-normal small">Status</th>
					<th class="py-3 text-muted fw-normal small">Assets</th>
					<th class="py-3"></th>
				</tr>
			</thead>
			<tbody>
				{{#each users}}
				<tr style="border-top:1px solid #f5f5f5">
					<td class="px-4 py-3 fw-medium">{{this.name}}</td>
					<td class="py-3 text-muted">{{this.email}}</td>
					<td class="py-3">
						<span style="background:#eef2fb;color:#3d5fa0;border-radius:20px;padding:3px 12px;font-size:.8rem;font-weight:500">
							{{this.role}}
						</span>
					</td>
					<td class="py-3">
						{{#if (eq this.status 'active')}}
						<span style="background:#e8f5e9;color:#2e7d32;border-radius:20px;padding:3px 12px;font-size:.8rem;font-weight:500">
							Active
						</span>
						{{else}}
						<span style="background:#fdecea;color:#c62828;border-radius:20px;padding:3px 12px;font-size:.8rem;font-weight:500">
							Inactive
						</span>
						{{/if}}
					</td>
					<td class="py-3">{{this.assets}}</td>
					<td class="py-3 pe-4">
						<a href="/users/{{this.id}}/edit"
						   style="border:1px solid #ddd;border-radius:6px;padding:3px 14px;font-size:.82rem;color:#333;text-decoration:none;background:#fff">
							Edit
						</a>
					</td>
				</tr>
				{{else}}
				<tr>
					<td colspan="6" class="text-center text-muted py-5 px-4">
						<i class="bi bi-people fs-4 d-block mb-2"></i>
						No users found.
					</td>
				</tr>
				{{/each}}
			</tbody>
		</table>
	</div>
</div>
